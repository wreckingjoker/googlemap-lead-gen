VITE_N8N_WEBHOOK_URL=https://justsearchweb.app.n8n.cloud/webhook/google-map-leads
VITE_N8N_ENRICH_URL=https://justsearchweb.app.n8n.cloud/webhook/enrich-lead

# Google Sheets history (optional — omit to use localStorage only)
# n8n workflow: Webhook POST → Google Sheets (Append Row) node
# Row columns: session_id | timestamp | query | location | business_name | phone | website | category | rating | reviews | maps_url
VITE_N8N_SHEETS_SAVE_URL=https://justsearchweb.app.n8n.cloud/webhook/sheets-save

# n8n workflow: Webhook GET → Google Sheets (Read Rows) → Code node (group by session_id) → Respond to Webhook
# Response shape: { "sessions": [{ "sessionId", "timestamp", "query", "location", "leadCount", "leads": [...] }] }
VITE_N8N_SHEETS_HISTORY_URL=https://justsearchweb.app.n8n.cloud/webhook/sheets-history
